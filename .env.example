# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# AI Configuration
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514

# API Keys (add the ones you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/culinaire

# Credential Encryption (required for Settings → Integrations)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# Authentication
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
BCRYPT_ROUNDS=12

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@culinaire.kitchen

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# OAuth - Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:3001/api/auth/microsoft/callback

# reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
