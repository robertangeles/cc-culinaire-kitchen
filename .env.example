# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# AI Configuration (all AI routes through OpenRouter — one key for everything)
AI_MODEL=anthropic/claude-sonnet-4-20250514
OPENROUTER_API_KEY=

# Database — LOCAL dev only. Must be a local host (localhost/127.0.0.1): a boot
# guard in packages/server/src/db/index.ts refuses a remote host unless
# NODE_ENV=production. Production reads DATABASE_URL from the Render dashboard.
DATABASE_URL=postgresql://archos_dev:password@127.0.0.1:5432/culinaire_kitchen_dev

# Schema changes: this repo does NOT use drizzle-kit push/migrate (see
# wiki/synthesis/schema-drift-may-2026.md). Apply targeted tsx scripts under
# packages/server/scripts/ instead. Those scripts read DATABASE_URL from this
# .env, so they hit LOCAL by default. To target PROD deliberately, put the prod
# URL in .env.production.local (gitignored) and load it explicitly for that run.

# Credential Encryption (required for Settings → Integrations)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# Authentication
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
BCRYPT_ROUNDS=12

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@culinaire.kitchen

# OAuth - Google (Web flow: code-exchange via /api/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3009/api/auth/google/callback

# OAuth - Google (Mobile native flow: ID token verification via /api/auth/google/idtoken)
# Provision separate OAuth client IDs in Google Cloud Console for each platform.
# Android: requires the app's package name + SHA-1 cert fingerprint
#   (get fingerprint via `cd android && ./gradlew signingReport` in the mobile repo).
# iOS: requires the app's bundle ID. Leave blank if not building for iOS.
# These are accepted as valid `audience` values by verifyGoogleIdToken.
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
