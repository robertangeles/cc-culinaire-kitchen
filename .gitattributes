# Normalise line endings: LF in the repo, OS-native on checkout if needed.
# Without this, Windows + Linux clones disagree on every text file.
* text=auto eol=lf

# Files that MUST keep CRLF on Windows
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Shell scripts must always be LF
*.sh    text eol=lf

# JSON / YAML / Markdown / source — all LF
*.json  text eol=lf
*.jsonc text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.env*  text eol=lf

# Binary — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary

# SVG is text, but treat as binary so editors don't normalise it.
*.svg   binary

# Lockfiles: text, LF, but don't show in `git diff` by default.
pnpm-lock.yaml  text eol=lf -diff
package-lock.json text eol=lf -diff
