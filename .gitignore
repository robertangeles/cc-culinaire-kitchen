# Dependencies
node_modules/

# Build outputs
dist/
build/
.turbo/

# Loose TypeScript build artifacts anywhere in packages/ (shadow .tsx/.ts twins,
# break Vite import-analysis, and pollute git status). tsc with no outDir set
# emits next to source — these patterns catch the spillage everywhere it lands
# (src/, tests/, package roots for *.config.ts, etc.).
packages/**/*.js
packages/**/*.js.map
packages/**/*.d.ts
packages/**/*.d.ts.map
# Keep hand-written declaration shims:
!packages/client/src/vite-env.d.ts

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Testing
coverage/

# Misc
*.tsbuildinfo

# Throwaway local inspection scripts (e.g. _inspect.mjs at repo root)
/_*.mjs
/_*.ts
/_*.js

# Local tooling state
.claude/
.gstack/

# User uploads
uploads/

# E2E test artifacts
packages/client/e2e-screenshots/
packages/client/tests/e2e/_artifacts/
packages/client/tests/e2e/__snapshots__/
packages/client/playwright-report/
packages/client/test-results/

# E2E credentials
packages/client/.env.test
