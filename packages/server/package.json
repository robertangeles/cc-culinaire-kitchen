    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.30",
    "supertest": "^7.2.2",
    "tsx": "^4",
