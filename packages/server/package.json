    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1",
    "@ai-sdk/openai": "^1",
    "@culinaire/shared": "workspace:*",
