    "ai": "^4",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^16",
    "drizzle-orm": "^0.38",
    "express": "^5",
    "express-rate-limit": "^7",
    "gray-matter": "^4",
    "helmet": "^8",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "otplib": "^13.3.0",
